# 🏗️ Build output (dotnet)
**/bin/
**/obj/
**/*.dll
**/*.exe
**/*.pdb
bin/
obj/

# 🧬 EF Core migration snapshots (optional)
**/Migrations/

# But allow these specific ones
!processor/ClubCore/Migrations
!processor/ClubCore/Migrations/EventDb/
!processor/ClubCore/Migrations/CompetitorDb/


# 🧑‍💻 IDE and user-specific files
.vscode/
**/.vs/
*.user
*.suo
*.csproj.user


# 📊 Intermediate and extracted data
data/*.json
data/*.log
data/standings-*.json
data/extracted/
extracted_csv/*.csv
processor/logs/

# 🧪 Test artifacts
processor/ClubProcessor.Tests/test-data/
# Ignore test artefacts
/TestOutput/
/processor/TestOutput/
/processor/**/TestExtracted_*/

# 🗃️ SQLite DBs transient files anywhere
**/*.db-wal
**/*.db-shm


# 🧹 Temp and backup files
*.tmp
*.bak
*.swp
~$*

# 🖥️ OS-specific files
.DS_Store
Thumbs.db

# 📦 Keep published artifacts
!results/
!docs/

# 🐍 Python cache
__pycache__/
*.pyc

processor/ClubProcessor/Properties/launchSettings.json

# ✅ Allow club DBs to be committed
!data/club_events_*.db
!data/club_competitors_*.db

# Ignore all .db files in ClubProcessor/data
processor/ClubProcessor/data/*.db

# extractor artifacts and normalized workbooks
artifacts/
*.normalized.xlsx

# Ignore site generator outputs
/SiteOutput/*
!/SiteOutput/.gitkeep
/RoundRobinSiteOutput/*
!/RoundRobinSiteOutput/.gitkeep

# 🧪 Test coverage output (XPlat Code Coverage)
**/TestResults/
**/coverage.cobertura.xml

# 📊 Local HTML coverage reports
coverage-report/
coverage-report/**

# 🧪 Coverlet-style coverage folders (if ever used again)
**/coverage/


update.sh
